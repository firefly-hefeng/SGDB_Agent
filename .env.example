# SCeQTL-Agent V3 Environment Variables
# Copy this file to .env and fill in your values

# LLM API Keys (at least one required for full functionality)
KIMI_API_KEY=sk-your-kimi-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# Model override (optional, defaults to config.yaml value)
# KIMI_MODEL=kimi-k2.6

# Database path (optional, auto-discovered if not set)
# SCEQTL_DB_PATH=../database_development/unified_db/unified_metadata.db

# Server settings
# SCEQTL_HOST=0.0.0.0
# SCEQTL_PORT=8000
# SCEQTL_DEBUG=false

# Cost control
# SCEQTL_DAILY_BUDGET=50

# Rate limiting (requests per minute per IP)
# SCEQTL_RATE_LIMIT=60
